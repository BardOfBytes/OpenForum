# ============================================================
# OpenForum — Environment Variables
# Copy this file to .env and fill in the values.
# The API now fails fast at startup if required integration vars are missing.
# ============================================================

# ----------------------------------------------------------
# Supabase (Auth)
# Get these from: https://supabase.com/dashboard → Settings → API
# ----------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key

# ----------------------------------------------------------
# Google Sheets API (Phase 1 Storage)
# Create a Google Cloud service account with Sheets API access.
# Share your spreadsheet with the service account email.
# ----------------------------------------------------------
GOOGLE_SHEETS_ID=your-google-sheets-spreadsheet-id
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id

# ----------------------------------------------------------
# Upstash Redis (Caching & Rate Limiting)
# Get these from: https://console.upstash.com
# ----------------------------------------------------------
UPSTASH_REDIS_URL=redis://default:token@your-redis.upstash.io:6379
UPSTASH_REDIS_TOKEN=your-upstash-redis-token

# ----------------------------------------------------------
# AXUM Backend
# AXUM_JWT_SECRET: Supabase JWT secret for RS256 token validation.
# Find it in Supabase Dashboard → Settings → API → JWT Secret.
# ----------------------------------------------------------
AXUM_JWT_SECRET=your-supabase-jwt-secret

# ----------------------------------------------------------
# API URL (Frontend → Backend)
# In development: http://localhost:3001
# In production: https://your-api.onrender.com
# ----------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001

# ----------------------------------------------------------
# Frontend URL (used by Rust API for CORS)
# In development: http://localhost:3000
# In production: https://openforum.vercel.app
# ----------------------------------------------------------
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000

# ----------------------------------------------------------
# Rust API Server
# ----------------------------------------------------------
PORT=3001
RUST_LOG=openforum_api=debug,tower_http=debug
