# ============================================================
# OpenForum Web (Next.js) — Environment Variables
#
# Copy to .env.local and fill in real values (.env.local is gitignored).
# Every var here is NEXT_PUBLIC_* and is shipped to the browser bundle —
# only put values that are safe to expose publicly. Never add the Supabase
# service-role key or any server secret here; those belong to the API only.
# ============================================================

# Base origin of the Rust API. No trailing slash and no /api path —
# the client appends /api/v1/... itself (see src/lib/api/base-url.ts).
# Dev default when unset: http://localhost:3001
NEXT_PUBLIC_API_URL=https://your-api.onrender.com

# Supabase project URL (auth client)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase publishable (anon) key — safe for the browser.
# Use the new "Publishable Key" (sb_publishable_...) from Settings → API.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your-publishable-key
