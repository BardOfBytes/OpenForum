# ============================================================
# OpenForum API — Environment Variables (strict fail-fast)
#
# The Rust API loads variables via dotenvy, which walks up from the
# working directory — so the repo-root .env is picked up automatically.
# You normally do NOT need a separate apps/api/.env; use the root .env.
#
# Required vars abort startup if missing (see src/config.rs).
# Copy to .env and fill in real values. Never commit the filled file.
# ============================================================

# ----------------------------------------------------------
# Server
# ----------------------------------------------------------
PORT=3001
RUST_LOG=openforum_api=debug,tower_http=debug

# Frontend origin for CORS allow-origin (required)
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000

# ----------------------------------------------------------
# Supabase
# ----------------------------------------------------------
# Project URL — used by the auth middleware JWKS lookup (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase JWT secret for token validation (required)
# Supabase Dashboard → Settings → API → JWT Secret
AXUM_JWT_SECRET=your-supabase-jwt-secret

# Service-role key — server-only, used for Supabase Admin/PostgREST calls
# in the user-profile routes (src/routes/users.rs). NEVER expose to the client.
# Use the new "Secret Key" (sb_secret_...) from Settings → API.
SUPABASE_SERVICE_KEY=sb_secret_your-service-role-key

# ----------------------------------------------------------
# Articles storage
# ----------------------------------------------------------
# `postgres` to store articles in Supabase/Postgres; `sheets` for Google Sheets.
ARTICLES_PROVIDER=postgres

# Supabase pooler connection string. The :6543 transaction pooler is detected
# automatically and the SQLx statement cache is disabled to stay pooler-safe;
# the statement-cache-capacity=0 query param is belt-and-suspenders.
DATABASE_URL=postgres://postgres.your-project-ref:password@aws-1-region.pooler.supabase.com:6543/postgres?sslmode=require&statement-cache-capacity=0

# Supabase schema is applied externally; leave false unless intentionally
# running local SQLx migrations from the API on startup.
OPENFORUM_RUN_API_MIGRATIONS=false

# ----------------------------------------------------------
# Upload storage (Cloudinary)
# ----------------------------------------------------------
STORAGE_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_UPLOAD_FOLDER=openforum/articles

# ----------------------------------------------------------
# Upstash Redis (caching & rate limiting)
# Falls back to allow-all rate limiting if unreachable.
# Accepts UPSTASH_REDIS_URL/TOKEN or the *_REST_* fallback names.
# ----------------------------------------------------------
UPSTASH_REDIS_URL=rediss://default:token@your-redis.upstash.io:6379
UPSTASH_REDIS_TOKEN=your-upstash-redis-token
