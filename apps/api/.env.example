# ============================================================
# OpenForum API — Environment Variables (strict fail-fast)
# ============================================================

PORT=3001
RUST_LOG=openforum_api=debug,tower_http=debug

# Frontend URL for CORS allow-origin
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000

# Supabase URL + JWT secret (required by auth middleware/startup validation)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
AXUM_JWT_SECRET=your-supabase-jwt-secret

# ----------------------------------------------------------
# Articles storage
# ----------------------------------------------------------
# Supabase pooler URLs should include statement-cache-capacity=0 for SQLx.
DATABASE_URL=postgres://postgres.your-project-ref:password@aws-1-region.pooler.supabase.com:6543/postgres?sslmode=require&statement-cache-capacity=0
# Supabase schema is applied externally; leave false unless intentionally running local SQLx migrations.
OPENFORUM_RUN_API_MIGRATIONS=false

# ----------------------------------------------------------
# Upload storage
# ----------------------------------------------------------
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_UPLOAD_FOLDER=openforum

# Upstash Redis
UPSTASH_REDIS_URL=redis://default:token@your-redis.upstash.io:6379
UPSTASH_REDIS_TOKEN=your-upstash-redis-token
