# ============================================================
# OpenForum API — Environment Variables (local development)
# Copy to .env and fill in the values.
# ============================================================

PORT=3001
RUST_LOG=openforum_api=debug,tower_http=debug

# Supabase JWT secret (for RS256 token validation)
AXUM_JWT_SECRET=your-supabase-jwt-secret

# Google Sheets (Phase 1 storage)
GOOGLE_SHEETS_ID=your-google-sheets-spreadsheet-id
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Upstash Redis
UPSTASH_REDIS_URL=redis://default:token@your-redis.upstash.io:6379
UPSTASH_REDIS_TOKEN=your-upstash-redis-token

# CORS allowed origin (production)
CORS_ORIGIN=http://localhost:3000
